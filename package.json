{
  "name": "finsweet-reverse-proxy",
  "version": "2.0.0",
  "description": "The reverse proxy used for all finsweet.com sites.",
  "author": {
    "name": "Finsweet",
    "url": "https://www.finsweet.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finsweet/reverse-proxy.git"
  },
  "scripts": {
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "lint": "eslint ./src && prettier --check ./src",
    "lint:fix": "eslint ./src --fix && pnpm format",
    "check": "tsc --noEmit",
    "format": "prettier --write ./src",
    "update": "pnpm update -i -L -r"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251205.0",
    "@finsweet/eslint-config": "^3.0.3",
    "@finsweet/tsconfig": "^1.4.2",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "wrangler": "^4.53.0"
  },
  "dependencies": {
    "hono": "^4.10.7"
  }
}
